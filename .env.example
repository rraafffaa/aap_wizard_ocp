# AAP Deployment Wizard — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# JWT secret for API authentication (auto-generated if not set, but sessions won't persist across restarts)
JWT_SECRET=change-me-to-a-random-string

# TLS certificate Common Name (set to your hostname or IP)
TLS_CN=localhost

# CORS allowed origins (comma-separated, set to your app URL)
CORS_ORIGINS=https://localhost

# Azure OpenAI (optional — enables AI error diagnosis during deployment)
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
# AZURE_OPENAI_KEY=your-key-here
# AZURE_OPENAI_MODEL=gpt-4o
